# Environment: development | production
NODE_ENV=development

# Supabase PostgreSQL connection string
# Get from: Supabase Dashboard → Settings → Database → Connection String (URI mode)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT].supabase.co:5432/postgres

# Supabase Storage
# Get from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# JWT
JWT_SECRET=change_this_to_a_long_random_string

# Frontend URL (set to your Vercel URL in production)
FRONTEND_URL=http://localhost:5173

# Master/owner account
MASTER_EMAIL=owner@example.com
MASTER_PASSWORD=change_this_to_a_strong_password
